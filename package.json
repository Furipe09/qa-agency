{
  "name": "qa-agency-automation",
  "version": "1.0.0",
  "description": "E2E Test Suite for QA Agency - Checkout Flow",
  "scripts": {
    "test:e2e": "playwright test",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:checkout": "playwright test checkout.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "allure:report": "allure generate ./allure-results --clean -o ./allure-report",
    "allure:open": "allure open ./allure-report",
    "allure:clean": "rm -rf allure-results allure-report",
    "start": "echo 'Mock server would start here'",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.0.0",
    "allure-playwright": "^2.13.0",
    "allure-commandline": "^2.25.0",
    "typescript": "^5.0.0",
    "eslint": "^8.50.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "prettier": "^3.0.0"
  },
  "dependencies": {
    "dotenv": "^16.3.1"
  },
  "keywords": [
    "playwright",
    "e2e",
    "test-automation",
    "allure",
    "qa",
    "sdet"
  ],
  "author": "QA Agency",
  "license": "MIT"
}
